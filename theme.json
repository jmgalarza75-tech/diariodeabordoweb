{
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "palette": [
                { "name": "Accent", "slug": "accent", "color": "#c9a84c" },
                { "name": "Background", "slug": "bg", "color": "#000000" },
                { "name": "Foreground", "slug": "fg", "color": "#ffffff" },
                { "name": "Dim", "slug": "dim", "color": "#666666" }
            ],
            "custom": true,
            "link": true
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "'Space Grotesk', sans-serif",
                    "name": "Space Grotesk",
                    "slug": "sans"
                },
                {
                    "fontFamily": "'Space Mono', monospace",
                    "name": "Space Mono",
                    "slug": "mono"
                }
            ],
            "customFontSize": true
        },
        "layout": {
            "contentSize": "900px",
            "wideSize": "1400px"
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--bg)",
            "text": "var(--wp--preset--color--fg)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--typography--font-family--sans)",
            "lineHeight": "1.6"
        },
        "elements": {
            "link": {
                "color": { "text": "var(--wp--preset--color--accent)" },
                "typography": { "textDecoration": "none" }
            }
        }
    }
}
